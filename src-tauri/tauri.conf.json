{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LiliaGithub",
  "version": "0.1.0",
  "identifier": "com.liliagithub.desktop",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LiliaGithub",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "backgroundColor": "#181818",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
