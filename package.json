{
  "name": "lilia-github",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sena-nana/LiliaGithub.git"
  },
  "homepage": "https://github.com/sena-nana/LiliaGithub",
  "type": "module",
  "scripts": {
    "sync:app-config": "lilia-tools sync-app-config",
    "version:bump": "lilia-tools version-bump",
    "check:package-manager": "lilia-tools check-package-manager",
    "about:licenses": "node scripts/generate-open-source-license-manifest.mjs",
    "feature-status:generate": "node scripts/sync-feature-status.mjs",
    "feature-status:check": "node scripts/sync-feature-status.mjs --check",
    "dev": "lilia-build dev",
    "prebuild": "pnpm about:licenses",
    "build": "lilia-build build",
    "test": "lilia-build test",
    "docs:dev": "lilia-build docs dev",
    "docs:build": "lilia-build docs build",
    "docs:preview": "lilia-build docs preview",
    "preview": "lilia-build preview",
    "tauri": "lilia-build tauri",
    "tauri:dev": "lilia-build tauri-dev",
    "tauri:build": "lilia-build tauri-build",
    "tauri:build:no-bundle": "lilia-build tauri-build --no-bundle",
    "tauri:install": "lilia-build tauri-install",
    "liliaui:local": "pnpm check:package-manager && node scripts/lilia-ui-deps.mjs local",
    "liliaui:remote": "pnpm check:package-manager && node scripts/lilia-ui-deps.mjs remote",
    "liliaui:status": "pnpm check:package-manager && node scripts/lilia-ui-deps.mjs status",
    "verify": "pnpm feature-status:check && pnpm test && pnpm build && cargo check --manifest-path src-tauri/Cargo.toml",
    "agent-debug:verify": "node agent-debug/verify-agent-debug.mjs"
  },
  "dependencies": {
    "@lilia/build": "github:sena-nana/LiliaUI#aa0c1df985de80420764ca5d952afa29f47c4ea8&path:/packages/build",
    "@lilia/config": "github:sena-nana/LiliaUI#aa0c1df985de80420764ca5d952afa29f47c4ea8&path:/packages/config",
    "@lilia/tools": "github:sena-nana/LiliaUI#aa0c1df985de80420764ca5d952afa29f47c4ea8&path:/packages/tools",
    "@lilia/ui": "github:sena-nana/LiliaUI#aa0c1df985de80420764ca5d952afa29f47c4ea8&path:/packages/ui",
    "@lilia/ui-contract": "github:sena-nana/LiliaUI#aa0c1df985de80420764ca5d952afa29f47c4ea8&path:/packages/ui-contract",
    "@lilia/ui-foundation": "github:sena-nana/LiliaUI#aa0c1df985de80420764ca5d952afa29f47c4ea8&path:/packages/ui-foundation",
    "ansi_up": "^6.0.6",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "yaml": "^2.9.0"
  },
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=26.0.0 <27",
    "pnpm": ">=11.0.0 <12"
  }
}
