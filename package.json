{
  "name": "lilia-github",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sena-nana/LiliaGithub.git"
  },
  "homepage": "https://github.com/sena-nana/LiliaGithub",
  "type": "module",
  "scripts": {
    "sync:app-config": "lilia-tools sync-app-config",
    "version:bump": "lilia-tools version-bump",
    "check:package-manager": "lilia-tools check-package-manager",
    "about:licenses": "node scripts/generate-open-source-license-manifest.mjs",
    "feature-status:generate": "node scripts/sync-feature-status.mjs",
    "feature-status:check": "node scripts/sync-feature-status.mjs --check",
    "dev": "lilia-build dev",
    "prebuild": "yarn about:licenses",
    "build": "lilia-build build",
    "test": "lilia-build test",
    "docs:dev": "lilia-build docs dev",
    "docs:build": "lilia-build docs build",
    "docs:preview": "lilia-build docs preview",
    "preview": "lilia-build preview",
    "tauri": "lilia-build tauri",
    "tauri:dev": "lilia-build tauri-dev",
    "tauri:build": "lilia-build tauri-build",
    "tauri:build:no-bundle": "lilia-build tauri-build --no-bundle",
    "tauri:install": "lilia-build tauri-install",
    "liliaui:local": "yarn check:package-manager && node scripts/lilia-ui-deps.mjs local",
    "liliaui:remote": "yarn check:package-manager && node scripts/lilia-ui-deps.mjs remote",
    "liliaui:status": "yarn check:package-manager && node scripts/lilia-ui-deps.mjs status",
    "verify": "yarn feature-status:check && yarn test && yarn build && cargo check --manifest-path src-tauri/Cargo.toml",
    "agent-debug:verify": "node agent-debug/verify-agent-debug.mjs"
  },
  "dependencies": {
    "@lilia/build": "github:sena-nana/LiliaUI#workspace=@lilia/build&commit=634e355f50eaf492dd590c60c39bef558f91f303",
    "@lilia/config": "github:sena-nana/LiliaUI#workspace=@lilia/config&commit=634e355f50eaf492dd590c60c39bef558f91f303",
    "@lilia/tools": "github:sena-nana/LiliaUI#workspace=@lilia/tools&commit=634e355f50eaf492dd590c60c39bef558f91f303",
    "@lilia/ui": "github:sena-nana/LiliaUI#workspace=@lilia/ui&commit=634e355f50eaf492dd590c60c39bef558f91f303",
    "@lilia/ui-contract": "github:sena-nana/LiliaUI#workspace=@lilia/ui-contract&commit=634e355f50eaf492dd590c60c39bef558f91f303",
    "@lilia/ui-foundation": "github:sena-nana/LiliaUI#workspace=@lilia/ui-foundation&commit=634e355f50eaf492dd590c60c39bef558f91f303",
    "ansi_up": "^6.0.6",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "yaml": "^2.9.0"
  },
  "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697",
  "engines": {
    "node": ">=26.0.0 <27"
  },
  "resolutions": {
    "glob@npm:^10.4.2": "npm:13.0.6"
  }
}
